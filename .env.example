APP_ENV=development
APP_NAME='Stock Insight Backend'
API_PREFIX=/api/v1
SQLITE_DB_PATH=./data/app.db
ALLOWED_ORIGINS=http://localhost:3000
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
OPENAI_COMPAT_BASE_URL=http://localhost:1234/v1
OPENAI_COMPAT_API_KEY=dummy
OPENAI_COMPAT_MODEL=local-model
CHAT_MAX_TURNS=12
CACHE_TTL_OVERVIEW_SECONDS=300
CACHE_TTL_HISTORY_SECONDS=300
CACHE_TTL_NEWS_SECONDS=900
CACHE_TTL_FINANCIALS_SECONDS=3600
CACHE_TTL_EARNINGS_SECONDS=3600
CACHE_TTL_ANALYST_SECONDS=3600
